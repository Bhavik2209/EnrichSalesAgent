{
  "version": 2,
  "env": {
    "PYTHON_VERSION": "3.12"
  },
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "pythonVersion": "3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ],
  "envDirectory": "."
}
